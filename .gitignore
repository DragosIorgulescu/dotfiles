# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Install log (generated at runtime)
install.log

# Neovim local state (managed by lazy.nvim / mason at runtime)
nvim/plugin/
nvim/lazy-lock.json

# Zsh compiled files
zsh/.zcompdump*
*.zwc

# Local overrides (user-specific, may contain secrets)
zsh/.zshrc.local

# Editor swap / backup
*.swp
*.swo
*~
